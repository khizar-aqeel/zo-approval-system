# =============================================
# ZO Approval System — Environment Variables
# Copy these to Netlify Dashboard:
# Site Settings → Environment Variables
# =============================================

# Shopify Store URL (without https://)
SHOPIFY_STORE=essentials-london.myshopify.com

# Shopify Admin API Access Token (from ZO Approval System app)
SHOPIFY_TOKEN=YOUR_TOKEN_HERE

# Email where approval notifications will be sent
ADMIN_EMAIL=shop@essentialslondon.com

# SMTP Settings (for sending emails)
# If using Gmail:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password

# If using Outlook/Office365:
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=shop@essentialslondon.com
# SMTP_PASS=your-email-password
